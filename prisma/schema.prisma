generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("viewer")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  campaigns     Campaign[]     @relation("CampaignOwner")
  members       CampaignMember[]
  sendsOwned    Send[]         @relation("SendOwner")
  sendsCopy     Send[]         @relation("SendCopy")
  activityLogs  ActivityLog[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  description String?
  product     String?
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("planning")
  tags        String?
  notes       String?
  color       String?
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner         User             @relation("CampaignOwner", fields: [ownerId], references: [id])
  members       CampaignMember[]
  sends         Send[]
  activityLogs  ActivityLog[]
  importedFiles ImportedFile[]
}

model CampaignMember {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  role       String   @default("member")
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
}

model Send {
  id            String    @id @default(cuid())
  campaignId    String
  channel       String
  base          String?
  scheduledDate DateTime?
  scheduledTime String?
  status        String    @default("idea")
  phase         String?
  subject       String?
  audience      String?
  copyLink      String?
  copyOwnerId   String?
  sendOwnerId   String?
  platform      String?
  externalId    String?
  notes         String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  copyOwner    User?        @relation("SendCopy", fields: [copyOwnerId], references: [id])
  sendOwner    User?        @relation("SendOwner", fields: [sendOwnerId], references: [id])
  metrics      SendMetrics?
  activityLogs ActivityLog[]
}

model SendMetrics {
  id          String    @id @default(cuid())
  sendId      String    @unique
  sent        Int?
  delivered   Int?
  opens       Int?
  reads       Int?
  clicks      Int?
  openRate    Float?
  clickRate   Float?
  ctr         Float?
  conversions Int?
  revenue     Float?
  errors      Int?
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  send Send @relation(fields: [sendId], references: [id], onDelete: Cascade)
}

model ImportedFile {
  id         String   @id @default(cuid())
  campaignId String?
  filename   String
  status     String   @default("pending")
  rowsTotal  Int      @default(0)
  rowsOk     Int      @default(0)
  rowsError  Int      @default(0)
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign?   @relation(fields: [campaignId], references: [id])
  rows     ImportRow[]
}

model ImportRow {
  id           String   @id @default(cuid())
  importFileId String
  rowIndex     Int
  sheet        String
  data         String
  status       String   @default("pending")
  error        String?
  sendId       String?
  createdAt    DateTime @default(now())

  importFile ImportedFile @relation(fields: [importFileId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  campaignId String?
  sendId     String?
  action     String
  details    String?
  createdAt  DateTime @default(now())

  user     User?     @relation(fields: [userId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  send     Send?     @relation(fields: [sendId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
